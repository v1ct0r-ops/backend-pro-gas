# ============================================================
# Pro-Gas ERP Backend — Environment Variables
# Copy this file to .env and fill in the values before running.
# NEVER commit .env to version control.
# ============================================================

# PostgreSQL connection string from Neon.tech
# Required format: postgresql+psycopg2://user:password@host/dbname?sslmode=require
# Get this from: https://console.neon.tech -> your project -> Connection Details
DATABASE_URL=postgresql+psycopg2://user:password@ep-xxx-xxxxxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Application settings
APP_ENV=development
APP_DEBUG=True

# CORS allowed origins (comma-separated, no trailing spaces)
# Development: include your local Vite dev server port
# Production:  set to your Vercel domain only
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
